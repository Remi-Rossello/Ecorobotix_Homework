{
  "name": "agriwatch",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup:env": "cp -n packages/server/.env.example packages/server/.env",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "build": "npm run build -w packages/client",
    "start": "npm run start -w packages/server",
    "test": "npm run test -w packages/server && npm run test -w packages/client",
    "test:server": "npm run test -w packages/server",
    "test:client": "npm run test -w packages/client",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0"
  }
}
